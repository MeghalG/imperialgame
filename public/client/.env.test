# E2E Test Environment — points at Firebase Emulator
# Start emulator with: firebase emulators:start --only database
REACT_APP_FIREBASE_DATABASE_URL=http://localhost:9000
REACT_APP_FIREBASE_API_KEY=test-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=localhost
REACT_APP_FIREBASE_STORAGE_BUCKET=test-bucket
REACT_APP_FIREBASE_PROJECT_ID=imperial-test
